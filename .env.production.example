APP_NAME="Centrix ERP API"
APP_ENV=production
APP_DEBUG=false

# Production deploy: set APP_ENV=production in k8s/Docker env.
# Same *_PRODUCTION keys are used from the unified .env pattern (see .env.example).

APP_KEY_PRODUCTION=
APP_URL_PRODUCTION=https://centrixapi.betsassured.com

DB_CONNECTION=mysql
DB_HOST_PRODUCTION=
DB_PORT_PRODUCTION=3306
DB_DATABASE_PRODUCTION=centrix_erp
DB_USERNAME_PRODUCTION=
DB_PASSWORD_PRODUCTION=

APP_PLATFORM_COMPANY_CODE=PLATFORM
APP_ALLOW_ORG_PROVISIONING=false
PLATFORM_SUPER_ADMIN_EMAIL=
PLATFORM_SUPER_ADMIN_PASSWORD=

FRONTEND_URL=https://centrixerp.betsassured.com
CORS_ALLOWED_ORIGINS=https://centrixerp.betsassured.com
CORS_SUPPORTS_CREDENTIALS=false
TRUSTED_PROXIES=*
MPESA_CALLBACK_IP_CHECK=true
SANCTUM_TOKEN_EXPIRATION_MINUTES=1440

LOG_CHANNEL=stderr
LOG_LEVEL=warning

CACHE_STORE=redis
CACHE_ORGANIZATION_TTL=3600
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
# In Kubernetes, password comes from the redis-auth secret (Kiarithaini) — not this file.
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=

OPENAI_MODEL=gpt-4o-mini

MPESA_ENV=production

DB_ALLOW_DESTRUCTIVE_COMMANDS=false

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

BACKUP_ENABLED=true
BACKUP_NOTIFY_EMAIL=
BACKUP_RETENTION_DAYS=14
BACKUP_SCHEDULE_TIME=02:00
BACKUP_ATTACH_MAX_BYTES=10485760

BACKUP_GOOGLE_DRIVE_ENABLED=false
BACKUP_GOOGLE_DRIVE_CREDENTIALS=
BACKUP_GOOGLE_DRIVE_FOLDER_ID=
