APP_NAME="Centrix ERP API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.example.com

APP_PLATFORM_COMPANY_CODE=PLATFORM
APP_ALLOW_ORG_PROVISIONING=false
PLATFORM_SUPER_ADMIN_EMAIL=
PLATFORM_SUPER_ADMIN_PASSWORD=

FRONTEND_URL=https://app.example.com

LOG_CHANNEL=stderr
LOG_LEVEL=warning

# Production database (set APP_ENV=production and DB_ALLOW_DESTRUCTIVE_COMMANDS=false)
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=centrix-superdb
DB_USERNAME=
DB_PASSWORD=

CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=

OPENAI_MODEL=gpt-4o-mini

MPESA_ENV=production

# Never enable on production — blocks migrate:fresh, db:wipe, migrate:rollback, etc.
DB_ALLOW_DESTRUCTIVE_COMMANDS=false

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

BACKUP_ENABLED=true
BACKUP_NOTIFY_EMAIL=
BACKUP_RETENTION_DAYS=14
BACKUP_SCHEDULE_TIME=02:00
BACKUP_ATTACH_MAX_BYTES=10485760
