APP_NAME="Centrix ERP API"
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=Africa/Nairobi

# Set APP_ENV=production and APP_DEBUG=false to use *_PRODUCTION values.

# --- Local (APP_ENV=local) ---
APP_KEY_LOCAL=
APP_URL_LOCAL=http://localhost:8000

DB_HOST_LOCAL=127.0.0.1
DB_PORT_LOCAL=3306
DB_DATABASE_LOCAL=pos_erp
DB_USERNAME_LOCAL=root
DB_PASSWORD_LOCAL=

# --- Production (APP_ENV=production) ---
APP_KEY_PRODUCTION=
APP_URL_PRODUCTION=https://api.example.com

DB_HOST_PRODUCTION=
DB_PORT_PRODUCTION=3306
DB_DATABASE_PRODUCTION=centrix_erp
DB_USERNAME_PRODUCTION=
DB_PASSWORD_PRODUCTION=

DB_CONNECTION=mysql
DB_ALLOW_DESTRUCTIVE_COMMANDS=false

# LightStores legacy (shared MySQL credentials default for database.connections.legacy)
LEGACY_DB_DATABASE=lightstores_legacy

# Per-organization legacy archive is configured by platform super admin under
# Admin → Organizations → {tenant} → Settings → Legacy archive (enabled, database name, cutover).
# Restore full LightStores archive (all sale_* / route_* / debtor_* tables) before enabling legacy archive:
# php artisan legacy:restore-archive --database=lightstores_moonlight --sql=/path/to/LightStoresDBBackup.sql
# php artisan legacy:restore-archive --database=lightstores_moonlight --verify-only
# Master data → Centrix: php artisan legacy:import-lightstores --master-data --organization=ID --force
# Legacy DB → historical sales only (POS, mobile/route, debtor); materialize on demand for returns.

# Platform super-admin (provision orgs only; no tenant ERP modules on PLATFORM org).
APP_PLATFORM_COMPANY_CODE=PLATFORM
APP_ALLOW_ORG_PROVISIONING=true
PLATFORM_SUPER_ADMIN_EMAIL=
PLATFORM_SUPER_ADMIN_PASSWORD=

FRONTEND_URL=http://localhost:3000

# Security (production: lock origins and enable M-Pesa IP checks)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080
CORS_SUPPORTS_CREDENTIALS=false
# Browser web app: HttpOnly API token cookie (mobile keeps Bearer tokens).
WEB_COOKIE_AUTH=false
API_TOKEN_COOKIE_NAME=centrix_api_token
API_TOKEN_COOKIE_SECURE=false
API_TOKEN_COOKIE_SAME_SITE=none
# Server-side idle token revoke (align with session idle timeout in Admin → Security).
AUTH_SERVER_IDLE_REVOKE=false
AUTH_SESSION_IDLE_MINUTES=60
AUTH_SCREEN_LOCK_MINUTES=5
SANCTUM_TOKEN_EXPIRATION_MINUTES=1440
SANCTUM_TOKEN_EXPIRATION_BACKOFFICE=480
SANCTUM_TOKEN_EXPIRATION_POS=1440
SANCTUM_TOKEN_EXPIRATION_MOBILE=1440
TRUSTED_PROXIES=*
MPESA_CALLBACK_IP_CHECK=false

LOG_CHANNEL=stack
LOG_LEVEL=debug

CACHE_STORE=redis
CACHE_ORGANIZATION_TTL=3600
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost

OPENAI_MODEL=gpt-4o-mini
# Optional bootstrap for Platform → AI training (prefer saving keys in the platform console)
# PLATFORM_OPENAI_API_KEY=
# PLATFORM_OPENAI_MODEL=
# PLATFORM_OPENAI_BASE_URL=

MPESA_ENV=sandbox

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

BACKUP_ENABLED=true
# Stored on the "local" disk (storage/app/private). Default path: private/backups/database/
BACKUP_DISK=local
BACKUP_PATH=backups/database
BACKUP_NOTIFY_EMAIL=
BACKUP_RETENTION_DAYS=14
BACKUP_SCHEDULE_TIME=02:00
BACKUP_ATTACH_MAX_BYTES=0

# Background report exports + large fetch row cache (JSONL). Must use storage shared by API and queue workers.
# Default: private/backups/exports/ (sibling of database backups under storage/app/private/backups/)
BACKGROUND_EXPORT_DIRECTORY=private/backups/exports

# Upload scheduled/manual backups to Google Drive (service account JSON + shared folder)
BACKUP_GOOGLE_DRIVE_ENABLED=false
# Local dev: path to JSON on your machine. K8s: use container path + secret mount, or credentials_json below.
BACKUP_GOOGLE_DRIVE_CREDENTIALS=
# K8s-friendly: paste full service account JSON (single line, multiline in secret stringData, or base64).
BACKUP_GOOGLE_DRIVE_CREDENTIALS_JSON=
# Folder ID from the Drive URL — share that folder with the service account email as Editor.
BACKUP_GOOGLE_DRIVE_FOLDER_ID=
