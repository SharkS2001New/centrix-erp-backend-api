APP_NAME="POS ERP API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pos_erp
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost

# Default AI model/URL when an org leaves them blank (API keys are per-organization in Settings → AI).
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# M-Pesa: configure per organization in Admin → Settings → Finance (module_settings.finance.mpesa).
# Branch till/shortcode overrides: Admin → Branches → settings.mpesa.
# Legacy global env vars below are not used for POS checkout in multi-tenant mode.
MPESA_ENV=sandbox
