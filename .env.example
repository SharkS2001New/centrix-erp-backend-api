APP_NAME="Centrix ERP API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Platform super-admin (provision orgs only; no tenant ERP modules on PLATFORM org).
APP_PLATFORM_COMPANY_CODE=PLATFORM
APP_ALLOW_ORG_PROVISIONING=true
PLATFORM_SUPER_ADMIN_EMAIL=alpacke.tech@gmail.com
PLATFORM_SUPER_ADMIN_PASSWORD=

# Web app URL for password-reset links
FRONTEND_URL=http://localhost:3000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
# Local development database (production uses centrix-superdb — see .env.production.example)
DB_DATABASE=pos_erp
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost

# Default AI model/URL when an org leaves them blank (API keys are per-organization in Settings → AI).
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# M-Pesa: configure per organization in Admin → Settings → Finance (module_settings.finance.mpesa).
# Branch till/shortcode overrides: Admin → Branches → settings.mpesa.
# Legacy global env vars below are not used for POS checkout in multi-tenant mode.
MPESA_ENV=sandbox

# Production safety — blocks migrate:fresh, db:wipe, migrate:rollback, etc.
DB_ALLOW_DESTRUCTIVE_COMMANDS=false

# Server mail transport (used for backup notifications and org mail fallback)
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# Automated database backups (requires cron: * * * * * php artisan schedule:run)
BACKUP_ENABLED=true
BACKUP_NOTIFY_EMAIL=
BACKUP_RETENTION_DAYS=14
BACKUP_SCHEDULE_TIME=02:00
BACKUP_ATTACH_MAX_BYTES=10485760

PLATFORM_SUPER_ADMIN_EMAIL=alpacke.tech@gmail.com
PLATFORM_SUPER_ADMIN_PASSWORD=your-password-here