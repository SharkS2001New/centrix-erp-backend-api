APP_NAME="POS ERP API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pos_erp
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost

MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_TILLNUMBER=
MPESA_SHORTCODE=
MPESA_CHILD_STORECODE=
MPESA_PASSKEY=
# Must be a public HTTPS URL reachable by Safaricom (not localhost). Example with ngrok:
# Do not use "mpesa" in the URL path — Safaricom rejects it.
# MPESA_CALLBACK_URL=https://your-subdomain.ngrok-free.app/api/v1/payments/stk/callback
MPESA_CALLBACK_URL=
# Direct paybill/till payments (no STK) — Safaricom posts here after register-urls:
# MPESA_CONFIRMATION_URL=https://your-subdomain.ngrok-free.app/api/v1/payments/c2b/confirmation
MPESA_CONFIRMATION_URL=
# MPESA_VALIDATION_URL=https://your-subdomain.ngrok-free.app/api/v1/payments/c2b/validation
MPESA_VALIDATION_URL=
MPESA_ENV=sandbox
